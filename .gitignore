# --- Data artifacts ---
# Raw scraped HTML and the built vector index are reproducible, so we don't
# commit them. The CLEAN docs in data/processed/ ARE committed (they are the
# knowledge base and are needed for deployment).
data/raw/*
!data/raw/.gitkeep
data/chroma/

