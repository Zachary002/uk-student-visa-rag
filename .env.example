# =============================================================================
# Copy this file to ".env" and fill in your keys.  NEVER commit the real .env.
#   cp .env.example .env
# In production (Hugging Face Spaces), set these as "Secrets" in the Space UI.
# =============================================================================

# --- LLM provider selection (the system is designed to be switchable) ---
# Supported values: anthropic (default). Can be extended to openai, etc.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# --- API keys ---
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Optional: only needed if you switch LLM_PROVIDER to openai
# OPENAI_API_KEY=
